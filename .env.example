# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX  # Voice-capable number — set webhook to POST /webhooks/voice

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_api_key

# ElevenLabs Text-to-Speech (voice agent — PR 3 of voice channel separation)
# Used by VoiceService.play_or_say to generate spoken audio for inbound + outbound voice calls.
# Falls back to Polly Joanna if any of these are missing or the API call fails.
ELEVENLABS_API_KEY=your_eleven_labs_api_key
ELEVENLABS_VOICE_ID=x8syuETaTA9JYwAbE2JM     # Ava — Captivating & Clear (SA-English) by default
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5        # Newer + more natural than multilingual_v2; still supports EN + AF

# Database
DATABASE_URL=postgresql://localhost/dr_leroux_receptionist_development

# WhatsApp Template Content SIDs (from Twilio Console)
WHATSAPP_TPL_CONFIRMATION=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_TPL_REMINDER_24H=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_TPL_REMINDER_1H=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_TPL_CANCELLATION=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_TPL_RESCHEDULE=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_TPL_FLAGGED_ALERT=HXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Reception WhatsApp number (for flagged patient alerts)
RECEPTION_WHATSAPP_NUMBER=+27XXXXXXXXXX

# App
BASE_URL=https://your-ngrok-url.ngrok.io
